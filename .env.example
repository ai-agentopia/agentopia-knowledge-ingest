# agentopia-knowledge-ingest — environment configuration
# Copy to .env.local and fill in values before starting the service.

# ── Database ──────────────────────────────────────────────────────────────────
# Required for document registry, job tracking, and audit log.
DATABASE_URL=postgresql://agentopia:agentopia@localhost:5432/agentopia_ingest

# ── Storage ───────────────────────────────────────────────────────────────────
# Set S3_BUCKET to use S3/MinIO. Leave empty to use local filesystem.
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT_URL=        # For MinIO: http://localhost:9000. Empty = AWS S3.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Local filesystem fallback (used when S3_BUCKET is empty)
STORAGE_LOCAL_PATH=/tmp/knowledge-store

# ── Super RAG integration ─────────────────────────────────────────────────────
# Required for indexing to work. Points to agentopia-super-rag service.
SUPER_RAG_URL=http://localhost:8002
SUPER_RAG_INTERNAL_TOKEN=local-dev-token
SUPER_RAG_INGEST_TIMEOUT_SECONDS=120
SUPER_RAG_INGEST_MAX_RETRIES=5

# ── Service ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=text    # text | json
PORT=8003
